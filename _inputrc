# Readline configuration for bash
# (zsh uses its own line editor and ignores this file)

# Type a partial command then use up/down arrow to search
# matching commands in history
"\e[A": history-search-backward
"\e[B": history-search-forward

# Case-insensitive tab completion
set completion-ignore-case On

# Show all matches immediately if ambiguous (no double-tab)
set show-all-if-ambiguous On

# Append a slash to completed symlinked directories
set mark-directories On
set mark-symlinked-directories On
